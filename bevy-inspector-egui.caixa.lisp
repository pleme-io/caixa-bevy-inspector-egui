   :body "name: test suite\non: [pull_request]\n\njobs:\n  test:\n    name: CI\n    runs-on: ubuntu-latest\n    steps:\n      - name: Install Linux dependencies\n        shell: bash\n        if: ${{ runner.os == 'linux' }}\n        run: >\n          sudo apt-get update\n\n          sudo apt-get install --no-install-recommends libwayland-dev\n      - uses: actions/checkout@v3\n      - uses: dtolnay/rust-toolchain@stable\n      - run: cargo test --all-features\n      - run: cargo fmt --all -- --check\n"}]
