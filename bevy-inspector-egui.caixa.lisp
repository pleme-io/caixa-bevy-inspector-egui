   :body "[workspace]\nresolver = \"2\"\nmembers = [\"crates/*\"]\n\n[workspace.dependencies]\negui = \"0.33\"\nbevy_egui = \"0.39\"\n"} {:path "crates/bevy-inspector-egui-derive/Cargo.toml"
